{
  "expo": {
    "name": "BabyMinimo",
    "slug": "babyminimo",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "babyminimo",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.babyminimo.app",
      "googleServicesFile": "./GoogleService-Info.plist"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FAF9F6"
      },
      "package": "com.babyminimo.app",
      "googleServicesFile": "./google-services.json"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-notifications",
      "expo-status-bar",
      [
        "expo-widgets",
        {
          "bundleIdentifier": "com.babyminimo.app.widgets",
          "groupIdentifier": "group.com.babyminimo.app",
          "enablePushNotifications": false,
          "frequentUpdates": false,
          "widgets": [
            {
              "name": "BabyMinimoCurrentStateWidget",
              "displayName": "BabyMinimo Snapshot",
              "description": "Shows your latest BabyMinimo care snapshot.",
              "contentMarginsDisabled": false,
              "supportedFamilies": [
                "systemSmall",
                "systemMedium"
              ]
            }
          ]
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.4"
          }
        }
      ]
    ]
  }
}
