# Local Firebase Emulator defaults. These EXPO_PUBLIC values are client-visible
# identifiers and emulator ports, not production secrets.
# Keep production service-account JSON, private keys, CI tokens, and App Store
# Connect keys outside Expo public environment variables.
EXPO_PUBLIC_FIREBASE_API_KEY=demo-api-key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=localhost
EXPO_PUBLIC_FIREBASE_PROJECT_ID=babyminimo-demo
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=babyminimo-demo.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
EXPO_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:babyminimodemo
EXPO_PUBLIC_USE_FIREBASE_EMULATOR=true
EXPO_PUBLIC_FIREBASE_EMULATOR_HOST=127.0.0.1
EXPO_PUBLIC_FIREBASE_AUTH_EMULATOR_PORT=9099
EXPO_PUBLIC_FIREBASE_FIRESTORE_EMULATOR_PORT=8080
EXPO_PUBLIC_FIREBASE_STORAGE_EMULATOR_PORT=9199
EXPO_PUBLIC_FIREBASE_FUNCTIONS_EMULATOR_PORT=5001
EXPO_PUBLIC_FIREBASE_UI_EMULATOR_PORT=4000
